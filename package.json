{
  "name": "mady-poc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "analyze": "ANALYZE=true next build",
    "payload": "payload",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "scrape": "tsx scripts/scrape-mady.ts",
    "extract-brand": "tsx scripts/extract-brand.ts",
    "seed": "tsx scripts/seed.ts",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@payloadcms/db-postgres": "3.83.0",
    "@payloadcms/next": "3.83.0",
    "@payloadcms/plugin-form-builder": "3.83.0",
    "@payloadcms/plugin-nested-docs": "3.83.0",
    "@payloadcms/plugin-seo": "3.83.0",
    "@payloadcms/richtext-lexical": "3.83.0",
    "@payloadcms/ui": "3.83.0",
    "@radix-ui/react-slot": "1.2.4",
    "@t3-oss/env-nextjs": "0.13.11",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.8.0",
    "next": "16.2.4",
    "next-intl": "4.9.1",
    "payload": "3.83.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.72.1",
    "sharp": "0.34.5",
    "tailwind-merge": "3.5.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.2",
    "@biomejs/biome": "2.4.12",
    "@next/bundle-analyzer": "16.2.4",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.2.2",
    "@types/culori": "4.0.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "cheerio": "1.2.0",
    "culori": "4.0.2",
    "dotenv": "17.4.2",
    "lefthook": "2.1.6",
    "robots-parser": "3.0.1",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "undici": "8.1.0",
    "vitest": "4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "lefthook",
      "esbuild",
      "@parcel/watcher",
      "@swc/core"
    ],
    "overrides": {
      "next": "16.2.4",
      "@next/env": "16.2.4",
      "react": "19.2.5",
      "react-dom": "19.2.5"
    }
  }
}
