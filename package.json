{
  "name": "mady-poc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=22.14.0 <25"
  },
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "analyze": "ANALYZE=true next build",
    "payload": "payload",
    "generate:types": "payload generate:types",
    "scrape": "tsx scripts/scrape-mady.ts",
    "extract-brand": "tsx scripts/extract-brand.ts",
    "seed": "tsx scripts/seed.ts",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.81.0",
    "@payloadcms/next": "^3.81.0",
    "@payloadcms/plugin-form-builder": "^3.81.0",
    "@payloadcms/plugin-nested-docs": "^3.81.0",
    "@payloadcms/plugin-seo": "^3.81.0",
    "@payloadcms/richtext-lexical": "^3.81.0",
    "@payloadcms/ui": "^3.81.0",
    "@t3-oss/env-nextjs": "^0.13.8",
    "next": "15.5.4",
    "next-intl": "^3.26.0",
    "payload": "^3.81.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@next/bundle-analyzer": "15.5.4",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "lefthook": "^2.1.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
